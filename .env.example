# Configuracion de Azure Cosmos DB
COSMOS_URL=https://TU-CUENTA.documents.azure.com:443/
COSMOS_KEY=PEGAR_PRIMARY_KEY_AQUI
COSMOS_DATABASE=TU_DB

# Contenedores existentes
COSMOS_CONTAINER_CARNETS=carnets_id
COSMOS_CONTAINER_NOTAS=notas
COSMOS_CONTAINER_CITAS=cita_id
COSMOS_CONTAINER_PROMOCIONES_SALUD=promociones_salud
COSMOS_CONTAINER_VACUNACION=Tarjeta de vacunacion
COSMOS_CONTAINER_USUARIOS=usuarios
COSMOS_CONTAINER_AUDITORIA=auditoria

# Comunicacion Institucional SASU 2.6.0
COSMOS_CONTAINER_TICKETS=tickets
COSMOS_CONTAINER_TICKET_MESSAGES=ticket_messages

# Partition Key para citas
COSMOS_PK_CITAS=/id

# Autenticacion JWT
JWT_SECRET_KEY=CAMBIAR_EN_PRODUCCION
SUPERVISOR_KEY=CAMBIAR_EN_PRODUCCION

# Google Calendar (opcional)
GCAL_ENABLED=false
GCAL_SA_JSON=path/to/service-account.json
GCAL_CALENDAR_ID=primary
APP_TZ=UTC

# Inicializacion segura de admin
INIT_ADMIN_API_BASE_URL=https://fastapi-backend-o7ks.onrender.com
INIT_ADMIN_PASSWORD=CAMBIAR_EN_PRODUCCION
